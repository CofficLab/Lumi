        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "請設定 LUMI_PREVIEW_HOST_EXECUTABLE 或將 LumiPreviewHostApp 嵌入 Contents/Helpers。"
          }
