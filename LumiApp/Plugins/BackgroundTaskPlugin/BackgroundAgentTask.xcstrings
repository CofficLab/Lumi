    "Receive instructions and execute tasks asynchronously in the background. Task results are stored in the plugin's own database.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Receive instructions and execute tasks asynchronously in the background. Task results are stored in the plugin's own database."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "接收指令并在后台异步执行任务，任务结果存储在插件自有数据库中。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "接收指令並在後台異步執行任務，任務結果存儲在插件自有數據庫中。"
          }
        }
      }
    },
