    "Create a background agent task to execute user instructions asynchronously. Suitable for long-running tasks that don't require real-time attention.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create a background agent task to execute user instructions asynchronously. Suitable for long-running tasks that don't require real-time attention."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "接收一条用户指令，将其保存为后台 Agent 任务并在后台异步执行。适用于需要长时间运行或不需要前台实时关注的任务。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "接收一條用戶指令，將其保存為後台 Agent 任務並在後台異步執行。適用於需要長時間運行或不需要前台實時關注的任務。"
          }
        }
      }
    },
    "Created At": {
      "localizations": {
        "en": {
