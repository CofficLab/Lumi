    "List recent background agent tasks and their status. Useful for understanding what tasks are running or have completed.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "List recent background agent tasks and their status. Useful for understanding what tasks are running or have completed."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "列出最近的后台 Agent 任务及其状态，供你了解有哪些任务正在运行或已经完成。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "列出最近的後台 Agent 任務及其狀態，供你了解有哪些任務正在運行或已經完成。"
          }
        }
      }
    },
    "Maximum number of tasks to return.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Maximum number of tasks to return."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "最多返回多少条任务记录，默认 20。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "最多返回多少條任務記錄，預設 20。"
          }
        }
      }
    },
