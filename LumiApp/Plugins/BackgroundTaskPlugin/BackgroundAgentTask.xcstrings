    },
    "Are you sure you want to clear all completed and failed tasks? This action cannot be undone.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to clear all completed and failed tasks? This action cannot be undone."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定要清除所有已完成和失败的任务吗？此操作不可撤销。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "確定要清除所有已完成和失敗的任務嗎？此操作不可撤銷。"
          }
        }
      }
    },
    "Background Agent Task": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Background Agent Task"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "后台 Agent 任务"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "後台 Agent 任務"
          }
        }
      }
    },
    "Background Agent task created. The system will process this instruction in the background. You can check the task status and results later in the status bar.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Background Agent task created. The system will process this instruction in the background. You can check the task status and results later in the status bar."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已创建后台 Agent 任务，系统会在后台继续处理此指令。你可以稍后在状态栏查看任务状态和结果。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "已創建後台 Agent 任務，系統會在後台繼續處理此指令。你可以稍後在狀態欄查看任務狀態和結果。"
          }
        }
      }
    },
    "Background task completed but no model response received.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Background task completed but no model response received."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "后台任务已完成，但未获得模型回复。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "後台任務已完成，但未獲得模型回覆。"
          }
        }
      }
    },
