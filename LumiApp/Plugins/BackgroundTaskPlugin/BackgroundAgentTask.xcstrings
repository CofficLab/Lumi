    "Get detailed information about a background agent task by ID, including instruction, status, result summary, and error message.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get detailed information about a background agent task by ID, including instruction, status, result summary, and error message."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "根据任务 ID 查询单个后台 Agent 任务的详细信息，包括指令、状态、结果摘要与错误信息。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "根據任務 ID 查詢單個後台 Agent 任務的詳細信息，包括指令、狀態、結果摘要與錯誤信息。"
          }
        }
      }
    },
    "Instruction": {
