    "Are you sure you want to clean %@ of Xcode cache? This action cannot be undone.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to clean %@ of Xcode cache? This action cannot be undone."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定要清理 %@ 的 Xcode 缓存吗？此操作无法撤销。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "確定要清理 %@ 的 Xcode 快取嗎？此操作無法復原。"
          }
        }
      }
    },
    "Are you sure you want to clean the selected %@ files? This action cannot be undone.": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to clean the selected %@ files? This action cannot be undone."
