{
  "sourceLanguage": "en",
  "strings": {
    "Xcode cleanup requires Full Disk Access. Please grant permission in System Settings.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Xcode 清理需要「完整磁盘访问权限」。请在系统设置中授予权限。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "Xcode 清理需要「完整磁碟存取權限」。請在系統設定中授予權限。"
          }
        }
      }
    },
    "Open System Settings": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开系统设置"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟系統設定"
          }
        }
      }
    },
    "Are you sure you want to clean %@ of Xcode cache? This action cannot be undone.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定要清理 %@ 的 Xcode 缓存吗？此操作无法撤销。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "確定要清理 %@ 的 Xcode 快取嗎？此操作無法復原。"
          }
        }
      }
    }
  },
  "version": "1.1"
}