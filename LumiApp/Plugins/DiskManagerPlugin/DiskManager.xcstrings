{
  "sourceLanguage": "en",
  "strings": {
    "Are you sure you want to clean %@ of Xcode cache? This action cannot be undone.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定要清理 %@ 的 Xcode 缓存吗？此操作无法撤销。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "確定要清理 %@ 的 Xcode 快取嗎？此操作無法復原。"
          }
        }
      }
    },
    "Are you sure you want to delete the selected build artifacts (node_modules, target, etc)? This will free up space but require rebuilding projects.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to delete the selected build artifacts (node_modules, target, etc)? This will free up space but require rebuilding projects."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to delete the selected build artifacts (node_modules, target, etc)? This will free up space but require rebuilding projects."
          }
        }
      }
    },
    "Xcode cleanup requires Full Disk Access. Please grant permission in System Settings.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Xcode 清理需要「完整磁盘访问权限」。请在系统设置中授予权限。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "Xcode 清理需要「完整磁碟存取權限」。請在系統設定中授予權限。"
          }
        }
      }
    }
  },
  "version": "1.1"
}