  "strings": {
    "'%@' does not belong to any compilation target.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "'%@' does not belong to any compilation target."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "'%@' 不属于任何编译目标。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "'%@' 不屬於任何編譯目標。"
          }
        }
      }
    },
    "\"%@\" is not bound to any compilation target. Cross-file semantic navigation may be unavailable.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" is not bound to any compilation target. Cross-file semantic navigation may be unavailable."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" 未绑定到任何编译目标。跨文件语义导航可能不可用。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" 未綁定到任何編譯目標。跨文件語義導航可能不可用。"
          }
        }
      }
    },
