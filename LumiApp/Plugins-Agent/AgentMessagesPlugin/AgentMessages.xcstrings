    "在下方输入框中输入您的问题，开始与 AI 助手对话": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter your question in the input box below to start chatting with the AI assistant"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在下方输入框中输入您的问题，开始与 AI 助手对话"
