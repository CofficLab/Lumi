    "Canvas is not square. App icons work best on a square canvas.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Canvas is not square. App icons work best on a square canvas."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "画布不是正方形。应用图标最适合使用正方形画布。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "畫布不是正方形。App 圖示最適合使用正方形畫布。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "畫布不是正方形。App 圖示最適合使用正方形畫布。"
