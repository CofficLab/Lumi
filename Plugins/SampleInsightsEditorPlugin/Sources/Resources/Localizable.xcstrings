    "Settings items from editor extensions are automatically grouped here.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Settings items from editor extensions are automatically grouped here."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "来自 editor extensions 的设置项会自动汇总到这个分组。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "來自 editor extensions 的設定項會自動彙總到這個分組。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "來自 editor extensions 的設定項會自動彙總到這個分組。"
          }
        }
      }
    },
    "This panel is contributed by SuperEditorPanelContributor and toggled from a titleTrailing status item.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This panel is contributed by SuperEditorPanelContributor and toggled from a titleTrailing status item."
