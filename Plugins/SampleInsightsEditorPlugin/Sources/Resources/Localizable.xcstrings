        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此面板由 SuperEditorPanelContributor 提供，通过 titleTrailing 状态项切换。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "此面板由 SuperEditorPanelContributor 提供，透過 titleTrailing 狀態項切換。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
