    "Break down complex goals into trackable tasks and drive Agent auto-progress.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Break down complex goals into trackable tasks and drive Agent auto-progress."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将复杂目标分解为可追踪的任务，并驱动 Agent 自动推进。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將複雜目標分解為可追蹤的任務，並驅動 Agent 自動推進。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "將複雜目標分解為可追蹤的任務，並驅動 Agent 自動推進。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "將複雜目標分解為可追蹤的任務，並驅動 Agent 自動推進。"
          }
        }
      }
    },
