    "Do not commit the .p8 key to source control or paste it into project files." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Do not commit the .p8 key to source control or paste it into project files."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "不要把 .p8 密钥提交到源码管理，也不要粘贴到项目文件中。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "不要把 .p8 密鑰提交到版本控制，也不要貼到專案檔案中。"
          }
        },
