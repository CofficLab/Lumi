          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请使用 MiniMax 开放平台 TokenPlan 套餐生成的 API Key，更新后重新发送消息。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請使用 MiniMax 開放平臺 TokenPlan 方案產生的 API Key，更新後重新發送訊息。"
          }
        },
