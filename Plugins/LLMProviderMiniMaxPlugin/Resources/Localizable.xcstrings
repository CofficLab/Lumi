    "Configure your MiniMax TokenPlan API Key below, then resend your message.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Configure your MiniMax TokenPlan API Key below, then resend your message."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请在下方填写 MiniMax TokenPlan API Key 后重新发送消息。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請於下方填寫 MiniMax TokenPlan API Key 後重新發送訊息。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
