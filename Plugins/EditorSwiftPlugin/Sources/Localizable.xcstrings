    "\"%@\" is not bound to any compilation target. Cross-file semantic navigation may be unavailable.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" is not bound to any compilation target. Cross-file semantic navigation may be unavailable."
