        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" 未绑定到任何编译目标。跨文件语义导航可能不可用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" 未綁定到任何編譯目標。跨文件語義導航可能不可用。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" 未綁定到任何編譯目標。跨文件語義導航可能不可用。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" 未綁定到任何編譯目標。跨檔案語義導航可能不可用。"
          }
        }
      }
    },
