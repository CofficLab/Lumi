{
  "sourceLanguage": "en",
  "strings": {
    "Plugins": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Plugins"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "插件"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "外掛"
          }
        }
      }
    },
    "Manage all registered plugins": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Manage all registered plugins"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "管理所有已注册的插件"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "管理所有已註冊的外掛"
          }
        }
      }
    },
    "Lists and manages all plugins registered with the kernel. Toggle a plugin to enable or disable it at runtime.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lists and manages all plugins registered with the kernel. Toggle a plugin to enable or disable it at runtime."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "列出并管理内核已注册的所有插件。切换开关可在运行时启用或禁用插件。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "列出並管理核心已註冊的所有外掛。切換開關可在執行時啟用或停用外掛。"
          }
        }
      }
    },
