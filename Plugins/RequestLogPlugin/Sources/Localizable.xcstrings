    "PluginDescription": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Log every chat request data, for debugging and auditing."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "记录每次聊天请求的发送数据，用于调试和审计。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "記錄每次聊天請求的發送數據，用於調試和審計。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "記錄每次聊天請求的發送數據，用於調試和審計。"
