    "After the first user message is sent, generate a short title by calling the model according to the default title rule.": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "After the first user message is sent, generate a short title by calling the model according to the default title rule."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "首条用户消息发送后，按默认标题规则调用模型生成简短标题。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "首條用戶消息發送後，按默認標題規則調用模型生成簡短標題。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "首條用戶消息發送後，按默認標題規則調用模型生成簡短標題。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "首條用戶消息發送後，按默認標題規則調用模型生成簡短標題。"
          }
        }
      }
    },
    "Are you sure you want to delete \"%@\"? This will permanently remove all messages and cannot be undone.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to delete \"%@\"? This will permanently remove all messages and cannot be undone."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定要删除对话「%@」吗？此操作将彻底删除该对话的所有消息，且无法恢复。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "確定要刪除對話「%@」嗎？此操作將徹底刪除該對話的所有訊息，且無法恢復。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "確定要刪除對話「%@」嗎？此操作將徹底刪除該對話的所有訊息，且無法恢復。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "確定要刪除對話「%@」嗎？此操作將徹底刪除該對話的所有訊息，且無法恢復。"
          }
        }
      }
    },
