    "Availability is inferred from local chat history and provider registration. Use the Current tab to pick a model manually, or enable Auto routing.": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Availability is inferred from local chat history and provider registration. Use the Current tab to pick a model manually, or enable Auto routing."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可用性根据本地聊天历史和提供商注册推断。使用 Current 选项卡手动选择模型，或启用自动路由。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "可用性根据本地聊天历史和提供商注册推断。使用 Current 选项卡手动选择模型，或启用自动路由。"
