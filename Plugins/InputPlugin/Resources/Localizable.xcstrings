    "Open Input Manager from the sidebar to review your settings.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open Input Manager from the sidebar to review your settings."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从侧边栏打开输入管理器来查看您的设置。"
