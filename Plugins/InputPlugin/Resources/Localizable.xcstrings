        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加应用和对应的输入源，切换应用时自动切换输入法"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "添加應用和對應的輸入源，切換應用時自動切換輸入法"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "添加應用和對應的輸入源，切換應用時自動切換輸入法"
