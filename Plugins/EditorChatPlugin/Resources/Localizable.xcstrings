    "Adds an \"Add to Chat\" command to the editor context menu to append the selected code's file reference to the chat composer.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Adds an \"Add to Chat\" command to the editor context menu to append the selected code's file reference to the chat composer."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在编辑器右键菜单中添加「添加到对话」命令，把所选代码的文件引用追加到对话输入框。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在編輯器右鍵選單中加入「加入對話」命令，將所選程式碼的檔案參照附加到對話輸入框。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "在編輯器右鍵選單中加入「加入對話」命令，將所選程式碼的檔案參照附加到對話輸入框。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "在編輯器右鍵選單中加入「加入對話」命令，將所選程式碼的檔案參照附加到對話輸入框。"
          }
        }
      }
    }
  },
  "version": "1.0"
}
